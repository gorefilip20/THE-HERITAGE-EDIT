# ─────────────────────────────────────────────────────────────
# THE HERITAGE EDIT — Production environment template
# Copy to `.env.production` (or set these in hPanel → Node.js App → Environment
# variables) and fill in real values. NEVER commit the filled-in file.
# ─────────────────────────────────────────────────────────────

# ── Core (REQUIRED) ──────────────────────────────────────────
# PostgreSQL connection string. Use a managed Postgres (Neon, Supabase,
# Railway) or a Postgres database you create in hPanel. Must be reachable
# from the Hostinger server. Include ?sslmode=require for most managed hosts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Secret used to sign login (JWT) cookies. Generate a long random string:
#   openssl rand -base64 48
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="https://yourdomain.com"

# Your live domain — used for canonical URLs, CORS, and payment callbacks.
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

NODE_ENV="production"

# ── Payments — Paystack (primary) ────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxxx"

# ── Payments — Stripe (secondary, optional) ──────────────────
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxxxxxxxxxxx"

# ── Payments — Flutterwave (optional) ────────────────────────
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_SECRET_HASH=""

# ── AI heritage narratives (optional — falls back to built-in
#    placeholder copy if both are absent) ──────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── Redis cache (OPTIONAL — app runs without it via a safe
#    in-memory fallback; set for multi-instance caching) ───────
REDIS_URL=""

# ── Transactional email — Resend (optional) ──────────────────
RESEND_API_KEY=""

# ── Image hosting — Cloudinary (optional) ────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Shipping — EasyPost (optional) ───────────────────────────
EASYPOST_API_KEY=""

# ── Shopify sync (optional) ──────────────────────────────────
SHOPIFY_SHOP_DOMAIN=""
SHOPIFY_ACCESS_TOKEN=""
